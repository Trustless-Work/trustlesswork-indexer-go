# Example environment file for the Indexer.
#
# Copy this file to .env and edit values for your local environment.
# The Makefile loads .env automatically when running `make run`.
# In production, set these via your container orchestrator (Docker,
# Kubernetes, systemd unit), not via .env files.
#
# Required variables have no default. Optional variables show their
# default in a comment above each line.

# =============================================================================
# RPC
# =============================================================================

# REQUIRED. Soroban RPC endpoint. Must match the network configured below.
RPC_URL=https://soroban-testnet.stellar.org

# Optional, default 30s.
# RPC_REQUEST_TIMEOUT=30s

# =============================================================================
# Network
# =============================================================================

# Optional, default "testnet".
NETWORK_NAME=testnet

# Optional, default is the testnet passphrase. Change to
#   Public Global Stellar Network ; September 2015
# for mainnet.
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# =============================================================================
# Indexer tunables
# =============================================================================

# Optional, default 0 (= start from the current RPC tip on first boot).
# After the first run the persisted state file is the source of truth;
# this is only consulted when no state exists yet OR STATE_RESET=true.
# INDEXER_START_LEDGER=0

# Optional, default 0 (= unbounded / live mode). Set to a positive
# value to bound a backfill run.
# INDEXER_END_LEDGER=0

# Optional, default "rpc". "datastore" is reserved for a future S3/GCS
# implementation and currently errors at startup.
# INDEXER_LEDGER_BACKEND_TYPE=rpc

# Optional, default 100. Buffer size hint for the SDK ledger reader.
# INDEXER_GET_LEDGERS_LIMIT=100

# Optional, default 0 (= auto). Caps the per-ledger worker pool. Useful
# for resource-constrained environments.
# INDEXER_WORKERS=0

# Optional, default false. Strips transaction meta / envelope XDR from
# captured records to reduce memory. Affects only the legacy buffer
# path; safe to leave at default.
# INDEXER_SKIP_TX_META=false
# INDEXER_SKIP_TX_ENVELOPE=false

# =============================================================================
# Sink
# =============================================================================

# Optional, default "noop". One of: noop, rabbitmq.
# The "noop" sink discards everything; useful for dev runs that only
# exercise the detection path.
SINK_TYPE=noop

# REQUIRED if SINK_TYPE=rabbitmq. AMQP connection string. The password
# (if any) is redacted in the boot log.
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Optional, default "stellar.events". Topic exchange where envelopes
# are published. The Indexer declares it durable at boot.
# RABBITMQ_EXCHANGE=stellar.events

# Optional, default true. When true, every Publish blocks until the
# broker acks. Strongly recommended in production.
# RABBITMQ_PUBLISHER_CONFIRMS=true

# =============================================================================
# State (cursor + watchlist)
# =============================================================================

# Optional, default ./indexer.state.json. Path to the durable state
# file. The directory is created if missing. A sibling .lock file
# enforces single-writer semantics.
# STATE_PATH=./indexer.state.json

# Optional, default false. When true, the existing state file is
# ignored on this boot; the next Save overwrites it normally. Use to
# force a fresh start without manually deleting state files.
# STATE_RESET=false

# Optional, default "". Path to a JSON array of escrow contract IDs to
# seed the watchlist on first boot. The file is read once when the
# state file does not exist; subsequent boots ignore it.
# WATCHLIST_SEED_PATH=

# =============================================================================
# Health / observability
# =============================================================================

# Optional, default true. Disable to run without an HTTP server
# (useful for one-shot backfill runs).
# HEALTH_ENABLED=true

# Optional, default 8080. Port for /healthz, /readyz, /metrics, /status.
# HEALTH_PORT=8080

# =============================================================================
# Logging
# =============================================================================

# Optional, default "info". One of: panic, fatal, error, warn, info,
# debug, trace.
LOG_LEVEL=info

# Optional, default "auto". One of: auto, json, text.
#   - auto: text when stdout is a TTY, JSON otherwise.
#   - json: always JSON. Recommended in production.
#   - text: always human-readable. Recommended in dev.
LOG_FORMAT=auto

# =============================================================================
# Error policy
# =============================================================================

# Optional, default true. When true, skippable errors (per-event
# parse failures, malformed XDR) halt the loop. When false, they are
# logged at ERROR and the cursor advances. Production defaults to
# true so silent data loss is impossible; dev can set false to keep
# the loop alive while debugging.
STRICT_MODE=true
